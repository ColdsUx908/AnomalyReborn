CAServerConfig: {
	DisplayName: 服务器设置

	Contents: {
		Label: 启用模组内容
		Tooltip: 启用或禁用由 Calamity Anomalies 模组提供的内容。
	}
}

CAClientConfig: {
	DisplayName: 客户端设置

	AuxiliaryVisualEffects: {
		Label: 辅助视觉效果
		Tooltip: 可能有助于指示实体的某些行为或状态的辅助视觉效果。
	}

	UseCalamityStyleTextures: {
		Label: 使用灾厄风格的纹理
		Tooltip: 将模组中的某些纹理替换为与 Calamity Mod 的艺术风格更一致的版本。
	}
}
